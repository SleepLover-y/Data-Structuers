#include<iostream>
#include<cstdlib>
#include<cstddef>
using namespace std;

typedef int ElemType; // 定义二叉树节点数据类型
// 定义二叉树节点结构体
typedef struct TreeNode
{
    ElemType data;           // 节点存储的数据（关键字）
    struct TreeNode* lchild; // 左子节点
    struct TreeNode* rchild; // 右子节点
} TreeNode;

typedef TreeNode* BiTree; // 定义二叉树指针类型

// 先序遍历打印二叉树结点值（调试用）
void preOrder(BiTree T)
{
    if (T == NULL)
    {
        return;
    }

    printf("%d ", T->data);  // 访问当前节点
    preOrder(T->lchild);     // 遍历左子树
    preOrder(T->rchild);     // 遍历右子树
}

// 查找元素是否存在于二叉排序树中
// 如果找到，pos 指向该结点，返回 1
// 如果未找到，pos 指向应插入位置的父节点，返回 0

int search_bst(BiTree T, int value, BiTree parent, BiTree* pos)
{
    if (T == NULL)
    {
        *pos = parent; // 递归到空节点，查找失败，将父节点返回
        return 0;
    }

    if (T->data == value)
    {
        *pos = T; // 找到目标值
        return 1;
    }

    if (T->data > value)
    {
        return search_bst(T->lchild, value, T, pos); // 要查找的值比当前节点小，往左子树找
    }
    else
    {
        return search_bst(T->rchild, value, T, pos); // 要查找的值比当前节点大，往右子树找
    }
}

//向二叉排序树中插入一个值
//如果该值已存在，插入失败，返回0；否则插入成功，返回1

int insert_bst(BiTree *T, int value) {
    BiTree parent, pos;//parent用于辅助serach_bst,   pos表示插入位置或已经存在的位置
    BiTree curr;
    //查找插入位置
    int status = search_bst(*T, value, NULL, &pos);
        if (status == 0) {
            curr = (BiTree)malloc(sizeof(TreeNode));
            curr->data = value;
            curr->lchild = NULL;
            curr->rchild = NULL;
            if (pos == NULL) {
                *T = curr;
            }
            //插入为左子节点
            else if (value < pos->data) {
                pos->lchild = curr;
            }
            //插入为右子节点
            else {
                pos->rchild = curr;
            }
            return 1;
        }

        else {
            //如果已存在 不插入
            return 0;
        }

 }


int main()
{
    int i = 0;
    BiTree T = NULL;

    // 准备插入的初始序列
    int treeArr[] = { 70, 55, 49, 30, 39, 53, 80, 75, 98, 95 };

    // 批量插入
    for (int i = 0; i < 10; i++)
    {
        insert_bst(&T, treeArr[i]);
    }

    preOrder(T); // 查看当前树结构
    cout << "\n";

    insert_bst(&T, 99); // 插入一个新值 99
    preOrder(T); // 再次查看树结构
    cout << "\n";

    return 0;
}
