//获取队列元素个数
int queueSize(Queue* q) {
	if (!isEmpty(q)) {
		return q->rear - q->front;
	}
	else {
		return 0;
	}
}
//获取最大层数
int maxDepth(TreeNode* root) {
	if (root == NULL) {
		return 0;
	}
	int depth = 0;
	Queue* q = initQueue();
	equeue(q, root);
	while (!isEmpty(q)) {
		int count = queueSize(q);
		while (count > 0) {
			TreeNode* curr;
			dequeue(q, &curr);
			if (curr->lchild != NULL) {
				equeue(q, curr->lchild);
			}
			if (curr->rchild != NULL) {
				equeue(q, curr->rchild);
			}
			count--;
		}
		depth++;
	}
	return depth;
}
