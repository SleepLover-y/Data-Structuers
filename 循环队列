#include<iostream>
#include<cstdlib>
#include<cstddef>
using namespace std;
constexpr int maxsize = 100;
typedef int elemtype;
typedef struct {
	elemtype* data;
	int front, rear;
}Queue;
static Queue* initqueue() {
	Queue* q = (Queue*)malloc(sizeof(Queue));
	if (q == NULL) {
		return NULL;
	}
	q->data = (elemtype*)malloc(sizeof(elemtype) * maxsize);
	q->front = 0;
	q->rear = 0;
	return q;
}
static int equeue(Queue* q,elemtype e) {
	if ((q->rear + 1) % maxsize == q->front) {
		cout << "full" << endl;
		return 0;
	}
	q->data[q->rear] = e;
	q->rear = (q->rear + 1) % maxsize;
	return 1;
}
static int dequeue(Queue* q, elemtype* e) {
	if (q->front == q->rear) {
		cout << "empty" << endl;
		return 0;
	}
	*e = q->data[q->front];
	q->front = (q->front + 1) % maxsize;
	return 1;
}
int main() {
	Queue* q;
	q = initqueue();
	equeue(q, 10);
	equeue(q, 20);
	equeue(q, 30);
	equeue(q, 33);
	equeue(q, 75);
	elemtype e;
	dequeue(q, &e);
	cout << e << endl;
	dequeue(q, &e);
	cout << e << endl;
	system("pause");

	return 0;
}
