}
// 冒泡排序函数：按权重从大到小排序
static void bubbleSort(Edge* edges, int n) {
	for (int i = 0; i < n - 1; i++) {
		// 标记本轮是否有交换，优化排序
		bool swapped = false;
		for (int j = 0; j < n - 1 - i; j++) {
			// 从大到小排序，所以用小于号
			if (edges[j].weight > edges[j + 1].weight) {
				// 交换元素
				Edge temp = edges[j];
				edges[j] = edges[j + 1];
				edges[j + 1] = temp;
				swapped = true;
			}
		}
		// 如果没有交换，说明已经有序，提前退出
		if (!swapped) break;
	}
}

static int find(int* parent, int index) {

	while (parent[index] > 0) {
		index = parent[index];
	}

	return index;

}


static void KrusKal(Mat_Graph G) {
	Edge edges[maxedge];
	int k = 0;
	for (int i = 0; i < G.vertex_num; i++) {

		for (int j = i + 1; j < G.vertex_num; j++) {

			if (G.arc[i][j] < max1) {
				edges[k].begin = i;
				edges[k].end = j;
				edges[k].weight = G.arc[i][j];
				k++;
			}

		}

	}

	bubbleSort(edges,G.edge_num);

	int parent[maxsize];

	for (int i = 0; i < G.vertex_num; i++) {
		parent[i] = 0;
	}
	int n, m;
	for (int i = 0; i < G.edge_num; i++) {
		n = find(parent, edges[i].begin);
		m = find(parent, edges[i].end);

		if (n != m) {
			parent[n] = m;
			cout << '(' << G.vertex[edges[i].begin] << ',' << G.vertex[edges[i].end ]<< ')';
		}
	}

}



int main() {
	Mat_Graph G;
	create_graph(&G);
	KrusKal(G);
	return 0;
}
