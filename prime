#include<iostream>
#include<cstdlib>
#include<cstddef>
using namespace std;
typedef char VertexType;
typedef int EdgeType;
constexpr int max1 = 0x7fffffff;
constexpr int maxsize = 100;
typedef struct {
	VertexType vertex[maxsize];
	EdgeType arc[maxsize][maxsize];
	int vertex_num;
	int edge_num;
}Mat_Graph;

static void create_graph(Mat_Graph* G) {
	G->vertex_num = 9;
	G->edge_num = 15;
	G->vertex[0] = 'A';
	G->vertex[1] = 'B';
	G->vertex[2] = 'C';
	G->vertex[3] = 'D';
	G->vertex[4] = 'E';
	G->vertex[5] = 'F';
	G->vertex[6] = 'G';
	G->vertex[7] = 'H';
	G->vertex[8] = 'I';
	for (int i = 0; i < G->vertex_num; i++) {
		for (int j = 0; j < G->vertex_num; j++) {
			if (i ==j)
				G->arc[i][j] = 0;
			else
				G->arc[i][j] = max1;
		}
	}
	//连线
	G->arc[0][1] = 10;
	G->arc[0][5] = 11;
	G->arc[1][2] = 18;
	G->arc[1][6] = 16;
	G->arc[1][8] = 12;
	G->arc[2][3] = 22;
	G->arc[2][8] = 8;
	G->arc[3][4] = 20;
	G->arc[3][6] = 24;
	G->arc[3][7] = 16;
	G->arc[3][8] = 21;
	G->arc[4][5] = 26;
	G->arc[4][7] = 7;
	G->arc[5][6] = 17;
	G->arc[6][7] = 19;
	for (int i = 0; i < G->vertex_num; i++) {
		for (int j = 0; j < G->vertex_num; j++) {
			G->arc[j][i] = G->arc[i][j];
		}
	}
}
//prim*****
static void prim(Mat_Graph* G) {
	int i = 0;
	int j = 0;
	int k = 0;
	int min;
	int weight[maxsize];//侯选边
	int vex_index[maxsize];//数组的值表示出发点，下表表示指向点
	//先从顶点A开始
	weight[0] = 0;
	vex_index[0] = 0;//vex_index的值与下标对应

	for (i = 1; i < G->vertex_num; i++) {
		weight[i] = G->arc [0][i];
		vex_index[i] = 0;
	}


	//找到最小权与之连接
	for (int i = 1; i < G->vertex_num; i++) {
		min = max1;
		j = 0;
		k = 0;

		while (j < G->vertex_num) {

			if (weight[j] != 0 && weight[j] < min) {
				min = weight[j];
				k = j;
			}

			j++;
		}

        cout << '(' << G->vertex[vex_index[k]] << ',' << G->vertex[k] << ')' << endl;
	    weight[k] = 0;//k已经被选  不能作为侯选边
	    //找新节点的待选路径
	    for (int j = 0; j < G->vertex_num; j++) {

		//与新节点的可连接边进行比较，有比weight小的就替换

		    if (weight[j] != 0 && G->arc[k][j] < weight[j]) {
			    weight[j] = G->arc[k][j];
			    vex_index[j] = k;
		    }

	    }

	}


	
}
int main() {
	Mat_Graph G;
	create_graph(&G);
	prim(&G);
	return 0;
}
